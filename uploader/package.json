    "catch-unknown": "^2.0.0",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "mkdirp": "^3.0.1",
    "morgan": "^1.10.1",
    "multer": "2.1.1",
    "prom-client": "^15.1.3",
    "qs": "^6.15.2",
    "redis": "^5.12.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@testcontainers/minio": "^12.0.1",
    "@types/body-parser": "^1.19.6",
    "@types/busboy": "^1.5.4",
