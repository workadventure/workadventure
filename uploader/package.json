    "@typescript-eslint/parser": "^8.60.0",
    "@workadventure/eslint-config": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "form-data": "^4.0.6",
