{
  "name": "@workadventure/tailwind",
  "version": "1.0.0",
  "description": "Tailwind Theme for WorkAdventure",
  "type": "module",
  "style": "./style/index.css",
  "exports": {
    ".": "./style/index.css",
    "./style.css": "./style/index.css",
    "./style/index.css": "./style/index.css",
    "./tailwind-config": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "author": "WorkAdventure",
  "license": "ISC",
  "sideEffects": [
    "*.css",
    "style/*.css"
  ],
  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@workadventure/design-system": "^3.0.0",
    "tailwindcss": "^4.3.0"
  },
  "files": [
    "src/index.ts",
    "style/index.css",
    "tailwind.config.ts"
  ]
