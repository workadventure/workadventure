{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [ "ES2020" ],
    "module": "esnext",
    "moduleResolution": "bundler",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "skipLibCheck": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/ts-proto-generated/**/*.ts"]
}
