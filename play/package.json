    "url": "https://github.com/thecodingmachine/workadventure/issues"
  },
  "homepage": "https://github.com/thecodingmachine/workadventure#readme",
  "scripts": {
    "start": "if [ -n \"$STARTUP_COMMAND\" ]; then sh -c \"$STARTUP_COMMAND\"; fi && TSX_TSCONFIG_PATH=tsconfig-pusher.json tsx ./src/server.ts",
    "old_start": "node -r source-map-support/register --max-old-space-size=4096 ./dist/server.js",
    "dev": "cross-env concurrently --kill-others-on-fail \"npm:dev-front\" \"npm:typesafe-i18n-watch\" \"npm:watch-iframe-api\" \"npm:svelte-check-watch\" \"npm:dev-pusher\"",
    "dev-front": "cross-env vite",
    "dev-pusher": "TSX_TSCONFIG_PATH=tsconfig-pusher.json tsx watch --clear-screen=false --inspect=0.0.0.0:9229 ./src/server.ts",
    "build": "echo \"Compiling with options: $NODE_OPTIONS \" && cross-env vite build",
    "typecheck": "cross-env tsc --noEmit",
    "profile": "if [ -n \"$STARTUP_COMMAND\" ]; then sh -c \"$STARTUP_COMMAND\"; fi && TSX_TSCONFIG_PATH=tsconfig-pusher.json node --prof --import tsx ./src/server.ts",
    "push-sentry-sourcemaps": "tsc --project tsconfig-pusher.json && sentry-cli sourcemaps inject dist/ && sentry-cli releases new $SENTRY_RELEASE && sentry-cli sourcemaps upload dist --release=\"$SENTRY_RELEASE\" && sentry-cli releases finalize $SENTRY_RELEASE",
    "build-iframe-api": "vite --config iframe-api.vite.config.ts build",
    "watch-iframe-api": "npm run build-iframe-api -- --watch",
    "build-typings": "cross-env tsc --project tsconfig-for-iframe-api-typings.json",
    "precommit": "lint-staged",
    "test": "PLAY_URL=http://play.workadventure.localhost ADMIN_URL= vitest",
    "test:coverage": "PLAY_URL=http://play.workadventure.localhost ADMIN_URL= vitest --coverage",
    "svelte-check-watch": "cross-env NODE_PATH=./node_modules svelte-check --fail-on-warnings --threshold error --compiler-warnings \"a11y-media-has-caption:ignore,a11y-no-onchange:ignore,a11y-autofocus:ignore,a11y-media-has-caption:ignore,a11y-click-events-have-key-events:ignore,security-anchor-rel-noreferrer:ignore\" --watch",
    "svelte-check": "cross-env NODE_PATH=./node_modules svelte-check --fail-on-warnings --compiler-warnings \"a11y-media-has-caption:ignore,a11y-no-onchange:ignore,a11y-autofocus:ignore,a11y-media-has-caption:ignore,a11y-click-events-have-key-events:ignore,security-anchor-rel-noreferrer:ignore\"",
    "lint": "eslint src/ tests/",
    "lint-fix": "eslint --fix src/ tests/",
    "pretty": "prettier --write 'src/**/*.{ts,svelte}'",
    "pretty-check": "prettier --check 'src/**/*.{ts,svelte}'",
    "typesafe-i18n": "typesafe-i18n --no-watch",
    "typesafe-i18n-watch": "typesafe-i18n",
    "i18n:diff": "TSX_TSCONFIG_PATH=tsconfig.json tsx ./scripts/diff-i18n.ts",
    "i18n:check": "TSX_TSCONFIG_PATH=tsconfig.json tsx ./scripts/diff-i18n.ts --check"
  },
  "lint-staged": {
    "*.svelte": [
      "cross-env NODE_PATH=./node_modules svelte-check --compiler-warnings \"a11y-media-has-caption:ignore,a11y-no-onchange:ignore,a11y-autofocus:ignore,a11y-media-has-caption:ignore,a11y-click-events-have-key-events:ignore,security-anchor-rel-noreferrer:ignore\""
    ],
    "*.{ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
