{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "preserveValueImports": false,
    // Keep this false during the source migration so TypeScript can continue eliding value-less imports.
    "verbatimModuleSyntax": false,
  },
  "include": [
    "./src",
  ],
  "exclude": [
    "./src/front",
    "./src/svelte.ts",
    "./src/iframe_api.ts",
  ]
}
