{
    "name": "workadventure-desktop",
    "productName": "WorkAdventure",
    "version": "managedbyci",
    "description": "Desktop application for WorkAdventure",
    "author": "TheCodingMachine <hello@workadventu.re>",
    "homepage": "https://workadventu.re",
    "main": "dist/main.js",
    "license": "SEE LICENSE IN LICENSE.txt",
    "scripts": {
        "build": "tsup-node ./src/main.ts ./src/preload-app/preload.ts ./src/preload-pip/preload.ts ./src/preload-overlay/preload.ts ./src/preload-screen-identify/preload.ts ./src/preload-hud/preload.ts ./src/preload-tabs/preload.ts",
        "build:local-app": "echo 'local app is no longer bundled by the remote SaaS desktop shell'",
        "dev": "npm run build -- --watch --onSuccess 'electron dist/main.js'",
        "dev:local-app": "echo 'local app is no longer bundled by the remote SaaS desktop shell'",
        "bundle": "npm run build && electron-builder install-app-deps && electron-builder",
        "typecheck": "tsc --noEmit",
        "test": "node --test src/**/*.test.js",
        "lint": "eslint src/ . --ext .ts",
        "fix": "eslint --fix src/ . --ext .ts",
        "pretty": "prettier --write 'src/**/*.{ts,tsx}'",
        "pretty-check": "prettier --check 'src/**/*.{ts,tsx}'"
    },
    "dependencies": {
        "auto-launch": "^5.0.5",
        "electron-is-dev": "^2.0.0",
        "electron-log": "^4.4.6",
        "electron-serve": "^1.1.0",
        "electron-settings": "^4.0.2",
        "electron-updater": "^4.6.5",
        "electron-util": "^0.17.2",
        "electron-window-state": "^5.0.3",
        "node-fetch": "^3.2.10"
    },
    "devDependencies": {
        "@types/auto-launch": "^5.0.2",
        "@typescript-eslint/eslint-plugin": "^5.18.0",
        "@typescript-eslint/parser": "^5.18.0",
        "electron": "^42.4.1",
        "electron-builder": "^23.6.0",
        "eslint": "^8.12.0",
        "prettier": "^2.6.2",
        "tsup": "^5.12.4",
        "typescript": "^4.6.3"
    }
}
