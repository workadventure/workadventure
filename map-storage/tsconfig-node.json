{
  "compilerOptions": {
    "target": "ES2022",
    "downlevelIteration": true,
    "lib": ["ES2020"],
    "module": "esnext",
    "moduleResolution": "bundler",

    "sourceMap": true,
    "inlineSources": true,
    "outDir": "./dist",

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitThis": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,

    "sourceRoot": "/"
  },
  "exclude": [
    "./src-ui",
    "./dist",
    "./dist-ui",
    "./eslint.config.js",
    "./vite.config.ts"
  ]
}
